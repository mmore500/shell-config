#!/bin/bash
scheme=$(/usr/bin/gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null)
if [ "$scheme" = "'prefer-dark'" ]; then
    mode="dark"
else
    mode="light"
fi

# kitty
cp "$HOME/.config/kitty/theme-${mode}.conf" "$HOME/.config/kitty/current-theme.conf"
pkill -x -SIGUSR1 kitty 2>/dev/null || true

# VSCode
python3 -c "
import json, os, sys
path = os.path.expanduser('~/.config/Code/User/settings.json')
try:
    with open(path) as f:
        s = json.load(f)
    s['workbench.colorTheme'] = 'Solarized (dark)' if '${mode}' == 'dark' else 'Solarized Light'
    with open(path, 'w') as f:
        json.dump(s, f, indent=2)
        f.write('\n')
except Exception as e:
    print(f'kitty-theme-sync: vscode: {e}', file=sys.stderr)
" 2>/dev/null || true
