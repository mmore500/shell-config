[user]
	email = mmore500.login+gpg@gmail.com
	name = Matthew Andres Moreno
	signingkey = 0x4C80129901C855AA
[core]
	editor = vim
[commit]
	gpgSign = true
[init]
	defaultBranch = master
[url "https://"]
	insteadOf = git://
[safe]
	directory = *
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential]
	helper = cache
